# ACA Environment Variables -- copy to .env and fill values
# NEVER commit .env to git

# -------------------------
# Azure Identity (Phase 1 -- marco* sandbox)
# -------------------------
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# -------------------------
# Cosmos DB
# -------------------------
ACA_COSMOS_URL=https://marco-sandbox-cosmos.documents.azure.com:443/
ACA_COSMOS_KEY=
ACA_COSMOS_DB=aca-db

# -------------------------
# Azure OpenAI (Phase 1: marco-sandbox-openai-v2)
# -------------------------
ACA_OPENAI_ENDPOINT=https://marco-sandbox-openai-v2.openai.azure.com/
ACA_OPENAI_KEY=
ACA_OPENAI_DEPLOYMENT=gpt-4o

# -------------------------
# APIM (Phase 1: marco-sandbox-apim)
# -------------------------
ACA_APIM_SUBSCRIPTION_KEY=

# -------------------------
# Application Insights
# -------------------------
APPLICATIONINSIGHTS_CONNECTION_STRING=

# -------------------------
# Stripe
# -------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_TIER2_ONETIME=price_...
STRIPE_PRICE_TIER2_SUBSCRIPTION=price_...
STRIPE_PRICE_TIER3_ONETIME=price_...

# -------------------------
# ACA API
# -------------------------
ACA_API_SECRET_KEY=change-this-in-production
ACA_ALLOWED_ORIGINS=http://localhost:5173,https://app.aca.example.com
ACA_ENVIRONMENT=local

# -------------------------
# Frontend (Vite)
# -------------------------
VITE_ACA_API_BASE_URL=http://localhost:8080/v1
