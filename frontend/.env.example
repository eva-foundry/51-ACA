# -----------------------------------------------------------------------
# ACA Frontend -- Environment Variables
# Copy to .env.local for local development.
# Only VITE_ prefixed vars are exposed to the browser.
# -----------------------------------------------------------------------

# Google Tag Manager container ID (fires GA4 + Clarity)
VITE_GTM_CONTAINER_ID=GTM-XXXXXXX

# Microsoft Clarity project ID
VITE_CLARITY_PROJECT_ID=xxxxxxxxxxxx

# API base URL (default empty = Vite proxy to http://localhost:8000)
VITE_API_BASE_URL=
